# ── Backend .env.example ──────────────────────────────────────────────────────
# Copy this to valuai-backend/.env and fill in real values

# App
APP_ENV=development
FRONTEND_URL=http://localhost:3000

# Database — Railway PostgreSQL
DATABASE_PUBLIC_URL=postgresql://postgres:PASSWORD@monorail.proxy.rlwy.net:PORT/railway

# Groq (fast extraction + scoring)
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# Google AI (Gemini Vision + deep analysis + embeddings)
GOOGLE_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash
EMBEDDING_MODEL=models/text-embedding-004

# Optional — Firecrawl (web scraping — pipeline works without this)
FIRECRAWL_API_KEY=fc-...

# Optional — Fireant (Vietnamese stock data — falls back to hardcoded table)
FIREANT_TOKEN=...

# ── Frontend .env.local ──────────────────────────────────────────────────────
# Copy this to valuai-frontend/.env.local

# NEXT_PUBLIC_API_URL=http://localhost:8000
