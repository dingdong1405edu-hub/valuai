# ── App ──────────────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# ── Database (Railway PostgreSQL) ────────────────────────────────────
# Use PUBLIC URL for local dev, internal URL for Railway deploy
DATABASE_PUBLIC_URL=postgresql://postgres:PASSWORD@monorail.proxy.rlwy.net:PORT/railway
DATABASE_URL=postgresql://postgres:PASSWORD@postgres.railway.internal:5432/railway

# ── Groq (fast extraction & scoring) ────────────────────────────────
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# ── Google AI (Gemini + Embeddings) ─────────────────────────────────
GOOGLE_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash
EMBEDDING_MODEL=models/text-embedding-004

# ── Firecrawl (optional — web scraping) ─────────────────────────────
FIRECRAWL_API_KEY=fc-...

# ── Fireant (optional — Vietnamese market data) ──────────────────────
FIREANT_TOKEN=...
FIREANT_BASE_URL=https://restv2.fireant.vn

# ── Frontend URL (for CORS) ───────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
